# MongoDB
MONGODB_URI=mongodb://localhost:27017/game-x

# NextAuth (обов'язково, мінімум 16 символів)
AUTH_SECRET=your-secret-at-least-16-chars

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth (Discord)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Local dev credentials (only in development)
ENABLE_LOCAL_CREDENTIALS=true
DEV_ADMIN_EMAIL=admin@game-x.local
DEV_ADMIN_PASSWORD=change-me-admin-password
DEV_USER_EMAIL=user@game-x.local
DEV_USER_PASSWORD=change-me-user-password

NEXT_PUBLIC_DEV_ADMIN_EMAIL=admin@game-x.local
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=change-me-admin-password
NEXT_PUBLIC_DEV_USER_EMAIL=user@game-x.local
NEXT_PUBLIC_DEV_USER_PASSWORD=change-me-user-password

# Адміни (email через кому, без пробілів)
ADMIN_EMAILS=admin@example.com

# Cron для автоматичного звільнення ПК
CRON_SECRET=your-cron-secret

# Додаткові security налаштування
SEED_SECRET=your-seed-secret
TRUST_PROXY_HEADERS=false
